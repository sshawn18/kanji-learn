# Provided automatically by Railway PostgreSQL plugin — do not set manually on Railway
DATABASE_URL="postgresql://user:password@host:5432/dbname"

# Generate a strong random secret: openssl rand -base64 32
AUTH_SECRET="replace-with-a-long-random-string-at-least-32-chars"

# Your live domain once deployed, e.g. https://kanji-learn.up.railway.app
NEXTAUTH_URL="https://your-app.up.railway.app"
